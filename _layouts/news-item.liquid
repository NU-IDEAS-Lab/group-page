---
layout: default
---
<div class="post">
  <header class="post-header">
    {% if page.title %}
      <h1 class="post-title">{{ page.title }}</h1>
    {% endif %}
    {% if page.date %}
      <p class="post-meta">{{ page.date | date: '%b %Y' }}</p>
    {% endif %}
  </header>

  <article>
    {{ content }}
  </article>
</div>
