  month = sep,
  year = {2018},
  note = {Conference Name: Proceedings of the IEEE},
  keywords = {Mathematical model, Computational modeling, verification, Space exploration, design automation, Semantics, Codesign, Cyber-physical systems, synthesis, cyber–physical systems (CPSs), modeling, Unified modeling language},
  pages = {1484--1500},
}

